{
  "name": "react-guided-journey",
  "version": "1.1.0",
  "description": "Headless React onboarding system — guided tours with spotlight, a progress checklist, discovery banners and a help center. Zero runtime dependencies, router-agnostic, DB-ready persistence.",
  "keywords": [
    "react",
    "onboarding",
    "product-tour",
    "guided-tour",
    "walkthrough",
    "spotlight",
    "checklist",
    "user-onboarding",
    "tooltip",
    "coachmark",
    "headless",
    "tour",
    "feature-tour",
    "product-adoption",
    "user-guide",
    "tour-guide",
    "intro",
    "hint",
    "popover",
    "react-tour",
    "nextjs-onboarding",
    "react-joyride-alternative",
    "driver.js-alternative",
    "shepherd-alternative",
    "intro.js-alternative",
    "reactour-alternative"
  ],
  "homepage": "https://github.com/AlpeshB08/react-guided-journey#readme",
  "bugs": {
    "url": "https://github.com/AlpeshB08/react-guided-journey/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlpeshB08/react-guided-journey.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/AlpeshB08"
  },
  "license": "MIT",
  "author": "Alpesh Baraiya",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "directories": {
    "doc": "docs",
    "example": "example"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome check --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "module": "./dist/index.js",
  "sideEffects": [
    "**/*.css"
  ]
}
