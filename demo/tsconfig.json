{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "paths": {
      "react-guided-journey": ["../src/index.ts"],
      "react-guided-journey/styles.css": ["../src/styles.css"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
